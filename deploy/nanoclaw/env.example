NANOCLAW_IMAGE=ghcr.io/OWNER/REPO/nanoclaw:latest
COMPOSE_PROFILES=
OC_GO_CC_IMAGE=samueltuyizere/oc-go-cc:latest
OC_GO_CC_PORT=3456
OPENCODE_GO_API_BASE=

OC_GO_CC_API_KEY=replace-with-opencode-subscription-token
OPENCODE_API_KEY=replace-with-opencode-subscription-token

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_ID=replace-with-single-chat-id

TARGET_REPO=https://github.com/Stanislavussov/Polyglot
TARGET_BRANCH=master
TARGET_GITHUB_TOKEN=replace-with-fine-grained-pat

POLYGLOT_ENV_B64=

MAX_FIX_ATTEMPTS=3
LOG_TAIL_LINES=80
CANCEL_GRACE_MS=10000
GIT_TIMEOUT_MS=120000
OPENCODE_TIMEOUT_MS=3600000
REVIEW_TIMEOUT_MS=1800000
GATE_TIMEOUT_MS=1200000
OPENCODE_COMMAND=opencode
OPENCODE_RUN_ARGS=run --dangerously-skip-permissions
OPENCODE_REVIEW_ARGS=run
TOOLING_COMPOSE_FILE=deploy/nanoclaw-tooling/compose.yml
TOOLING_SERVICE=polyglot-tooling
VERIFY_INSTALL=pnpm install --frozen-lockfile
VERIFY_BUILD=pnpm build
VERIFY_LINT=pnpm lint
VERIFY_DEPS=pnpm lint:deps
VERIFY_TEST=pnpm test
